# LLM Provider (OpenAI-compatible)
OPENAI_API_KEY=sk-...

# Optional: override base URL for other providers (e.g., Groq, Together)
# OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Web Search API (e.g., Tavily, Serper, or custom)
TAVILY_API_KEY=tvly-...

# Financial Data (yfinance doesn't require an API key, but keep a slot)
# ALPHA_VANTAGE_API_KEY=...
